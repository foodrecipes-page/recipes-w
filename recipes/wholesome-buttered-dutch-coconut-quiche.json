      "amount": "1 tbsp"
    },
    {
      "name": "olive oil",
      "amount": "1 tbsp",
      "notes": "for brushing"
    },
    {
      "name": "unsalted butter",
      "amount": "1 tbsp",
      "notes": "for brushing"
    }
  ],
  "instructions": [
    "Preheat oven to 180°C and place the salt block on the middle rack to heat for 15 minutes.",
    "Combine flour and 1/2 tsp salt; add 3 tbsp melted butter and mix until crumbly, then press into a 9-inch round mold lined with parchment and bake for 10 minutes until lightly golden.",
    "Whisk eggs, milk, salt, pepper, dill, coconut flakes, and shredded cheese until smooth.",
    "Brush the heated salt block with 1 tbsp melted butter and pour the filling over the pre-baked crust.",
    "Bake on the salt block for 25 minutes until set and golden.",
    "Remove from oven, let rest 5 minutes, then slice and serve warm."
  ],
