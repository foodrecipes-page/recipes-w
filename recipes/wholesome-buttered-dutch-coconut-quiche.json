      "amount": "1 cup"
    },
    {
      "name": "unsalted butter",
      "amount": "3 tbsp",
      "notes": "melted for crust"
    },
    {
      "name": "whole milk",
      "amount": "1 cup"
    },
    {
      "name": "large eggs",
      "amount": "2"
    },
    {
      "name": "coconut flakes",
      "amount": "1/4 cup"
    },
    {
      "name": "Gouda cheese, shredded",
