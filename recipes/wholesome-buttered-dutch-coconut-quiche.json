{
  "title": "Wholesome Buttered Dutch Coconut Quiche",
  "description": "A buttery quiche with toasted coconut flakes baked on a salt block for a Dutch twist, ovo-vegetarian and delightfully bouncy.",
  "cuisine": "Dutch",
  "diet": [
    "vegetarian"
  ],
