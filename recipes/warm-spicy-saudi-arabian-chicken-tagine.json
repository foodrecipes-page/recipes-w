      "name": "boneless chicken breast",
      "amount": "1 pound",
      "notes": "cut into 1-inch pieces"
    },
    {
      "name": "coconut cream",
      "amount": "1/2 cup"
    },
    {
      "name": "ground cumin",
      "amount": "1 teaspoon"
    },
    {
      "name": "ground coriander",
      "amount": "1 teaspoon"
    },
    {
      "name": "ground cinnamon",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "ground nutmeg",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "cayenne pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "chicken broth",
      "amount": "1 cup"
    }
  ],
  "instructions": [
    "Heat the fondue pot over medium heat and add the chicken to cook until browned, about 5 minutes.",
    "Add the cumin, coriander, cinnamon, nutmeg, cayenne pepper, salt, and black pepper to the pot and cook for 1 minute.",
    "Pour in the chicken broth and bring the mixture to a boil.",
    "Reduce the heat to low and simmer, covered, for 10 minutes.",
    "Stir in the coconut cream and continue to simmer, uncovered, for an additional 5 minutes.",
    "Serve the tagine hot, garnished with fresh parsley or cilantro, if desired."
  ],
