{
  "title": "Warm Kenyan Dum Dumplings",
  "description": "A savory, comforting dish from Kenya, perfect for a midnight craving.",
  "cuisine": "kenyan",
  "diet": [
    "vegetarian"
  ],
  "meal": "snack",
  "ingredients": [
    {
      "name": "all-purpose white flour",
      "amount": "2 cups"
    },
    {
      "name": "warm water",
      "amount": "1 cup"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "vegetable oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "active dry yeast",
      "amount": "1 teaspoon"
    },
    {
      "name": "egg",
      "amount": "1 large"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "kale or spinach leaves",
      "amount": "1 cup"
    }
  ],
  "instructions": [
    "Combine flour, yeast, and salt in a large mixing bowl.",
    "Gradually add warm water, mixing until a dough forms.",
    "Knead the dough for 10 minutes until it becomes smooth.",
    "Place the dough in a greased bowl, cover, and let it rise in a warm place for 1 hour.",
    "Heat oil in a large skillet over medium heat.",
    "Punch down the dough and divide it into small balls.",
    "Fry the dumplings until they are golden brown, about 2 minutes per side.",
    "Drain the dumplings on paper towels.",
    "Serve the Warm Kenyan Dum Dumplings in a lacquerware bowl and garnish with kale or spinach leaves.",
    "Serve immediately and enjoy!"
  ],
