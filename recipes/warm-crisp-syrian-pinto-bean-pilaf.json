  ],
  "meal": "lunch",
  "ingredients": [
    {
      "name": "pinto beans",
      "amount": "1 cup",
      "notes": "dried, soaked overnight and drained"
    },
    {
      "name": "ferment-jang",
      "amount": "2 tbsp"
    },
    {
      "name": "olive oil",
      "amount": "2 tbsp"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "salt",
      "amount": "1 tsp"
    },
    {
      "name": "black pepper",
      "amount": "1 tsp"
    },
    {
      "name": "sumac",
      "amount": "1 tsp"
    },
    {
      "name": "fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Preheat the oven to 400 degrees Fahrenheit.",
    "In a large bowl, mix together the pinto beans, ferment-jang, olive oil, onion, garlic, salt, black pepper, and sumac.",
    "Transfer the mixture to a baking dish and bake for 30 minutes.",
    "Stir the pilaf and continue baking for an additional 10 minutes, or until the top is crispy and golden brown.",
    "Remove the pilaf from the oven and sprinkle with chopped fresh parsley.",
    "Let the pilaf cool for a few minutes before serving.",
    "Serve the pilaf warm, garnished with additional parsley if desired."
  ],
