{
  "title": "Warm Spanish Peanut Crema Catalana",
  "description": "A tangy and crumbly Spanish dessert featuring peanut oil, perfect for a post-workout treat",
  "cuisine": "Spanish",
  "diet": [
    "low-fat",
    "gluten-free"
  ],
  "meal": "dessert",
  "ingredients": [
    {
      "name": "peanut oil",
      "amount": "1/4 cup",
      "notes": "for brushing"
    },
    {
      "name": "eggs",
      "amount": "4 large",
      "notes": "at room temperature"
    },
    {
      "name": "granulated sugar",
      "amount": "1 cup"
    },
    {
      "name": "peanut butter",
      "amount": "1/2 cup",
      "notes": "creamy"
    },
    {
      "name": "sea salt",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "vanilla extract",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "heavy cream",
      "amount": "1 cup",
      "notes": "low-fat"
    },
    {
      "name": "brine-dried peanuts",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Preheat the robata grill to 375 degrees Fahrenheit",
    "In a medium bowl, whisk together the eggs, sugar, peanut butter, and sea salt until smooth",
    "Add the vanilla extract and whisk until combined",
    "Brush the peanut oil onto the grill and pour in the egg mixture",
    "Cook for 10 minutes or until the edges are set",
    "Remove from the grill and let cool for 5 minutes",
    "In a small bowl, whip the heavy cream until stiff peaks form",
    "Fold the whipped cream into the cooled egg mixture until well combined",
    "Stir in the chopped brine-dried peanuts",
    "Serve warm and enjoy"
  ],
