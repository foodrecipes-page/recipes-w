      "amount": "2 tsp"
    },
    {
      "name": "salt (pinch)",
      "amount": "pinch"
    },
    {
      "name": "black pepper (coarse grinds)",
      "amount": "coarse grinds"
    },
    {
      "name": "pandan leaf",
      "amount": "large leaf"
    },
    {
      "name": "water (50ml)",
      "amount": "50ml"
    }
  ],
  "instructions": [
    "Heat butter in a large pan over medium heat.",
    "Add namul-blanch-season and stir for 1 minute.",
    "Add smoked cod fillet and cook for 3-4 minutes or until flaked.",
    "Add white wine vinegar, honey, salt and black pepper, stir for 1 minute.",
    "Add Chinese leaves to the pan and wilt for 2-3 minutes.",
    "Transfer the mixture to a bowl and let it cool.",
    "Wet the surface of a large pandan leaf with water.",
    "Place a portion of the mixture onto the center of the pandan leaf and fold the leaf into a neat wrap.",
    "Repeat the process with the remaining ingredients.",
    "Serve immediately and enjoy."
  ],
