    },
    {
      "name": "Smoked Cod Fillet",
      "amount": "200g"
    },
    {
      "name": "butter (50g)",
      "amount": "50g"
    },
    {
      "name": "white wine vinegar (2 tbsp)",
      "amount": "2 tbsp"
    },
    {
