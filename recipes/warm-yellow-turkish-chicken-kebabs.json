{
  "title": "Warm Yellow Turkish Chicken Kebabs",
  "description": "A kid-friendly Turkish dish featuring chicken kebabs with a mustardy and molten glaze, made with yellow food coloring for a fun twist.",
  "cuisine": "Turkish",
  "diet": [
    "low-sodium"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "chicken breast",
      "amount": "1 pound",
      "notes": "cut into 1-inch pieces"
    },
    {
      "name": "yellow food coloring",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "honey",
      "amount": "1 tablespoon"
    },
    {
      "name": "Dijon mustard",
      "amount": "1 tablespoon"
    },
    {
      "name": "garlic powder",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "salt-free seasoning blend",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "wooden skewers",
      "amount": "10",
      "notes": "soaked in water for 30 minutes"
    }
  ],
  "instructions": [
    "Preheat the grill to medium-high heat.",
    "Thread the chicken pieces onto the wooden skewers.",
    "In a small bowl, whisk together the olive oil, lemon juice, honey, Dijon mustard, garlic powder, and salt-free seasoning blend.",
    "Brush the mixture onto both sides of the chicken kebabs.",
    "Grill the kebabs for 10-12 minutes, turning occasionally, until cooked through.",
    "In a small bowl, mix together the yellow food coloring and 1 tablespoon of water.",
    "Brush the yellow glaze onto the kebabs during the last 2 minutes of grilling.",
    "Serve the kebabs hot, garnished with fresh parsley if desired."
  ],
