      "name": "pandan leaves",
      "amount": "4",
      "notes": "fresh or dried"
    },
    {
      "name": "amaretti cookies",
      "amount": "6",
      "notes": "crushed"
    },
    {
      "name": "cashel blue cheese",
      "amount": "1 cup",
      "notes": "crumbly"
    },
    {
      "name": "dubliner cheese",
      "amount": "1 cup",
      "notes": "shredded"
    },
    {
      "name": "apple cider vinegar",
      "amount": "2 tbsp"
    },
    {
      "name": "coconut oil",
      "amount": "1 tsp"
    },
    {
      "name": "salt",
      "amount": "1/2 tsp"
    },
    {
      "name": "black pepper",
      "amount": "1/4 tsp"
    }
  ],
  "instructions": [
    "Preheat the oven to 350 degrees.",
    "Dehydrate the pandan leaves for 30 minutes.",
    "In a bowl, mix together the crushed amaretti cookies, cashel blue cheese, and dubliner cheese.",
    "Add the apple cider vinegar, coconut oil, salt, and black pepper to the bowl and mix until well combined.",
    "Spoon the cheese mixture onto the center of each pandan leaf.",
    "Fold the pandan leaves to form a wrap and place on a baking sheet.",
    "Bake for 10 minutes or until the cheese is melted and the pandan leaves are warm.",
    "Serve immediately and enjoy."
  ],
