      "amount": "2 tablespoons"
    },
    {
      "name": "tempering chocolate",
      "amount": "1 ounce"
    },
    {
      "name": "coconut milk",
      "amount": "1/4 cup"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "garlic",
      "amount": "2 cloves",
      "notes": "minced"
    },
    {
      "name": "ginger",
      "amount": "1 teaspoon",
      "notes": "grated"
    },
    {
      "name": "bamboo skewers",
      "amount": "10"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "pepper",
      "amount": "1/4 teaspoon"
    }
  ],
  "instructions": [
    "Preheat the grill to 400 degrees Fahrenheit.",
    "In a large bowl, whisk together gochujang, tempering chocolate, coconut milk, lemon juice, garlic, ginger, salt, and pepper.",
    "Add the chicken to the bowl and toss to coat with the marinade.",
    "Thread the chicken onto the bamboo skewers.",
    "Grill the skewers for 10-12 minutes, turning occasionally.",
    "Let the skewers rest for 2 minutes before serving.",
    "Serve the skewers warm, garnished with fresh cilantro if desired.",
    "Store any leftovers in an airtight container in the refrigerator for up to 3 days."
  ],
