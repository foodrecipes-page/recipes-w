{
  "title": "Warm Irish Summer Savoury Crumble",
  "description": "A sweet and savoury crumble dish perfect for a solo Irish dinner, featuring dried leaves of summer savoury and a hint of tandoor spice.",
  "cuisine": "Irish",
  "diet": [
    "kosher",
    "gluten-free"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "summer savoury leaves",
      "amount": "2 tablespoons dried"
    },
    {
      "name": "pearl sugar",
      "amount": "2 tablespoons"
    },
    {
      "name": "kosher salt",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "tandoor spice",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "quince jam",
      "amount": "2 tablespoons"
    },
    {
      "name": "all-purpose flour",
      "amount": "1 cup"
    },
    {
      "name": "cold unsalted butter",
      "amount": "1/2 cup"
    }
  ],
  "instructions": [
    "Preheat your oven to 375°F (190°C).",
    "In a large bowl, mix together the flour, quince jam, and cold butter until a crumbly mixture forms.",
    "Add the olive oil, salt, pepper, and tandoor spice to the mixture and stir until combined.",
    "Transfer the mixture to a 9x9-inch baking dish and top with the dried summer savoury leaves.",
    "In a separate bowl, mix together the pearl sugar and a pinch of salt.",
    "Sprinkle the sugar mixture evenly over the top of the crumble.",
    "Bake for 25-30 minutes or until the top is golden brown and the crumble is set.",
    "Remove from the oven and let cool for a few minutes before serving."
  ],
