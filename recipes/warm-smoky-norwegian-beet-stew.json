      "name": "beets",
      "amount": "2 large",
      "notes": "peeled and diced"
    },
    {
      "name": "smoked paprika",
      "amount": "2 tablespoons"
    },
    {
      "name": "carrots",
      "amount": "1 large",
      "notes": "peeled and sliced"
    },
    {
      "name": "potatoes",
      "amount": "2 large",
      "notes": "peeled and cubed"
    },
    {
      "name": "onion",
      "amount": "1 large",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "vegetable broth",
      "amount": "4 cups"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large Dutch oven over medium heat.",
    "Add the chopped onion and cook until it is translucent, about 5 minutes.",
    "Add the minced garlic and cook for an additional 1 minute.",
    "Add the diced beets, sliced carrots, and cubed potatoes, and cook for 5 minutes, stirring occasionally.",
    "Stir in the smoked paprika, salt, and black pepper.",
    "Pour in the vegetable broth and bring the mixture to a boil.",
    "Reduce the heat to low and simmer, covered, for 30 minutes, or until the vegetables are tender.",
    "Serve the stew hot, garnished with fresh herbs if desired."
  ],
