{
  "title": "Warm Juicy Mediterranean Lamb Tagine",
  "description": "A rich and flavorful Mediterranean dish featuring tender lamb, madras paste, and dark chocolate, cooked to perfection in a terracotta dish.",
  "cuisine": "Mediterranean",
  "diet": [
    "diabetic-friendly"
  ],
