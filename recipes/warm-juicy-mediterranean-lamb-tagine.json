      "name": "lamb shoulder",
      "amount": "1 1/2 pounds",
      "notes": "cut into 2 inch pieces"
    },
    {
      "name": "madras paste",
      "amount": "2 tablespoons"
    },
    {
      "name": "dark chocolate",
      "amount": "1 ounce",
      "notes": "broken into small pieces"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "onion",
      "amount": "1 large",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "dried apricots",
      "amount": "1/2 cup",
      "notes": "chopped"
    },
    {
      "name": "chicken broth",
      "amount": "1 cup"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Preheat the oven to 300 degrees Fahrenheit.",
    "Heat the olive oil in the terracotta dish over medium heat.",
    "Add the chopped onion and cook until it is softened and lightly browned.",
    "Add the minced garlic and cook for 1 minute.",
    "Add the lamb pieces and cook until they are browned on all sides.",
    "Add the madras paste, dark chocolate, dried apricots, chicken broth, salt, and black pepper, and stir to combine.",
    "Cover the dish with a lid and transfer it to the preheated oven.",
    "Bake for 2 1/2 hours, or until the lamb is tender and the sauce has thickened.",
    "Remove the dish from the oven and let it cool for 10 minutes before serving."
  ],
