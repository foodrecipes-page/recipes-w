  "ingredients": [
    {
      "name": "chicken breast",
      "amount": "1 1/2 pounds",
      "notes": "boneless and skinless"
    },
    {
      "name": "unsalted butter",
      "amount": "1/2 cup",
      "notes": "softened"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "aji amarillo peppers",
      "amount": "2 peppers",
      "notes": "diced"
    },
    {
      "name": "heavy cream",
      "amount": "1 cup",
      "notes": "full fat"
    },
    {
      "name": "grated parmesan cheese",
      "amount": "1/2 cup",
      "notes": "freshly grated"
    },
    {
      "name": "fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon",
      "notes": "to taste"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon",
      "notes": "to taste"
    }
  ],
  "instructions": [
    "Preheat the oven to 375 degrees Fahrenheit",
    "In a small saucepan, melt the butter over medium heat and cook until it turns golden brown and smells nutty",
    "Add the minced garlic and diced aji amarillo peppers to the saucepan and cook for 1 minute",
    "Stir in the heavy cream and bring the mixture to a simmer",
    "Reduce the heat to low and let the sauce simmer for 5 minutes",
    "Season the chicken breast with salt and black pepper",
    "Place the chicken breast in a terracotta dish and pour the beurre noisette sauce over the top",
    "Sprinkle the grated parmesan cheese over the chicken",
    "Bake the chicken in the preheated oven for 35 minutes",
    "Remove the chicken from the oven and sprinkle with chopped parsley"
  ],
