{
  "title": "Warm Silky Peruvian Chicken Bake",
  "description": "A rich and savory Peruvian dish featuring chicken baked in a silky beurre noisette sauce, perfect for a solo dinner",
  "cuisine": "Peruvian",
  "diet": [
    "gluten-free",
