      "name": "cumin seeds",
      "amount": "1 teaspoon"
    },
    {
      "name": "turmeric",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "water",
      "amount": "4 cups"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "Heat the ghee in a large pot over medium heat.",
    "Add the cumin seeds and let them sizzle for a few seconds.",
    "Add the chopped onion and cook until it is translucent.",
    "Add the minced garlic and grated ginger and cook for another minute.",
    "Add the red lentils, turmeric, and salt, and stir well.",
    "Add the water and bring the mixture to a boil.",
    "Reduce the heat to low and simmer for 20 minutes, or until the lentils are tender.",
    "Stir in the lemon juice and serve hot.",
    "Garnish with chopped fresh cilantro, if desired."
  ],
