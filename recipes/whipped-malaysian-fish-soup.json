{
  "title": "Whipped Malaysian Fish Soup",
  "description": "A citrusy, light, energizing fish soup with tomato juice, kombu extract, and fresh cucumber, perfect for a quick pescatarian lunch.",
  "cuisine": "Malaysian",
  "diet": [
    "pescatarian"
  ],
  "meal": "lunch",
  "ingredients": [
    {
      "name": "firm white fish fillets",
      "amount": "200g",
      "notes": "thinly sliced"
    },
    {
      "name": "tomato juice",
      "amount": "4 cups"
    },
    {
      "name": "kombu cold extract",
      "amount": "2 tbsp"
    },
    {
      "name": "shiitake mushrooms",
      "amount": "1 cup sliced"
    },
    {
      "name": "cucumber",
      "amount": "1 cup diced"
    },
    {
      "name": "lime juice",
      "amount": "1 tbsp"
    },
    {
      "name": "grated ginger",
      "amount": "1 tsp"
    },
    {
      "name": "red chili flakes",
      "amount": "1 tsp",
      "notes": "optional"
    },
    {
      "name": "salt",
      "amount": "1 tsp"
    },
    {
      "name": "coconut milk",
      "amount": "1 cup"
    }
  ],
  "instructions": [
    "Bring the tomato juice to a gentle boil in a medium pot.",
    "Add the kombu extract and stir until dissolved.",
    "Add the sliced fish and simmer for 4 minutes until the fish flakes easily.",
    "Add the mushrooms, cucumber, ginger, chili flakes, and salt and cook for an additional 2 minutes.",
    "Pour in the coconut milk and stir until combined.",
    "Remove the pot from heat and pour the soup into a blender to create a smooth texture.",
    "Add the lime juice and adjust seasoning if needed.",
    "Serve the soup warm, topped with a drizzle of sesame oil if desired."
  ],
