{
  "title": "Warm Egyptian Fish Bake",
  "description": "A tangy, silky single-dinner dish featuring kombu, lemon, orange, and tahini, perfect for a no-onion-no-garlic meal.",
  "cuisine": "egyptian",
  "diet": null,
  "meal": "dinner",
