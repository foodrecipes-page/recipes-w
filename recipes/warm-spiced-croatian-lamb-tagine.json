{
  "title": "Warm Spiced Croatian Lamb Tagine",
  "description": "A hearty and aromatic Croatian dish featuring lamb, citrus, and dark rum, cooked to perfection in an earthenware bowl, FODMAP friendly.",
  "cuisine": "Croatian",
  "diet": [
    "gluten-free",
    "low-lactose"
