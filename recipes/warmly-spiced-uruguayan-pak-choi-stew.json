      "name": "pak choi",
      "amount": "1 bunch",
      "notes": "chopped"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "malt syrup",
      "amount": "1 tablespoon"
    },
    {
      "name": "uruguayan chimichurri",
      "amount": "1/4 cup"
    },
    {
      "name": "vegetable broth",
      "amount": "2 cups"
    },
    {
      "name": "dried oregano",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large pot over medium heat.",
    "Add the chopped onion and cook until softened, about 5 minutes.",
    "Add the minced garlic and cook for an additional 1 minute.",
    "Add the chopped pak choi and cook until wilted, about 3 minutes.",
    "In a small bowl, whisk together the malt syrup, uruguayan chimichurri, and vegetable broth.",
    "Pour the mixture over the pak choi and bring to a boil.",
    "Reduce the heat to low and simmer, covered, for 20 minutes.",
    "Stir in the dried oregano, salt, and black pepper.",
    "Serve hot, garnished with additional chimichurri if desired."
  ],
