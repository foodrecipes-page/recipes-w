  "ingredients": [
    {
      "name": "mushrooms",
      "amount": "1 cup",
      "notes": "sliced"
    },
    {
      "name": "shoyu-koji",
      "amount": "2 tablespoons"
    },
    {
      "name": "corn husks",
      "amount": "4 pieces"
    },
    {
      "name": "onion",
      "amount": "1/2 cup",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "2 cloves",
      "notes": "minced"
    },
    {
      "name": "vegetable oil",
      "amount": "1 tablespoon"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Preheat a large skillet over medium heat.",
    "Add the vegetable oil and saute the onion and garlic until softened.",
    "Add the sliced mushrooms and cook until they release their moisture and start browning.",
    "Add the shoyu-koji and stir to combine.",
    "Season with salt and black pepper to taste.",
    "Warm the corn husks by wrapping them in a damp paper towel and microwaving for 20 seconds.",
    "Assemble the wraps by spooning the mushroom mixture onto a corn husk and serving immediately.",
    "Serve warm and enjoy."
  ],
