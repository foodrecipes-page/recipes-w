{
  "title": "Warm Spring Italian Allspice Berries Cassata",
  "description": "A citrusy and springy Italian dish featuring allspice berries, perfect for a brunch mood, with a plant-based friendly twist, served in a lotus leaf wrap.",
  "cuisine": "Italian",
  "diet": [
    "plant-based",
    "vegetarian"
  ],
  "meal": "breakfast",
  "ingredients": [
    {
      "name": "allspice berries",
      "amount": "1/2 cup",
      "notes": "dried"
    },
    {
      "name": "orange zest",
      "amount": "2 tablespoons"
    },
    {
      "name": "lemon juice",
      "amount": "1/4 cup"
    },
    {
      "name": "almond milk",
      "amount": "1 cup"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "lotus leaves",
      "amount": "4",
      "notes": "fresh"
    },
    {
      "name": "cannoli cream",
      "amount": "1 cup",
      "notes": "plant-based"
    },
    {
      "name": "sugar",
      "amount": "1/2 cup"
    }
  ],
  "instructions": [
    "Preheat the oven to 350 degrees.",
    "In a blender, combine allspice berries, orange zest, lemon juice, and almond milk, and blend until smooth.",
    "In a saucepan, heat the olive oil over medium heat.",
    "Add the blended mixture to the saucepan and stir until warm.",
    "Lay a lotus leaf flat and spoon some of the warm mixture onto the center of the leaf.",
    "Top with cannoli cream and sprinkle with sugar.",
    "Fold the lotus leaf over the filling to form a square shape.",
    "Repeat with the remaining ingredients.",
    "Place the cassata on a baking sheet and bake for 15 minutes."
  ],
