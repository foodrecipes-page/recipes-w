  "instructions": [
    "heat the iron teppan over medium-high heat.",
    "add the chicken breast and cook until browned on both sides, about 6 minutes.",
    "set the chicken aside and reduce heat to medium.",
    "saute the onion and garlic until softened, about 3 minutes.",
    "add the caraway seeds, salt, and pepper and cook for 1 minute.",
    "add the pasta and cook until al dente, stirring frequently.",
    "add the chicken stock and bring to a simmer.",
    "return the chicken to the pan and reduce heat to low.",
    "let it simmer for 10 minutes, stirring occasionally.",
    "serve the pasta and chicken hot, topped with grated parmesan."
